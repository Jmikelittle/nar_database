# macOS
.DS_Store

# Data directories - Exclude temporary working files (root level only)
/data/
/test_data/

# Database files - Never commit database files anywhere
*.db
*.sqlite
*.sqlite3

# Safety: Prevent accidental data file commits to docs/data/
docs/data/*.csv
docs/data/*.zip

# Temporary files
temp/
tmp/
*.tmp

# Logs
*.log
logs/

# OS generated files
Thumbs.db
